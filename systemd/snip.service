[Unit]
Description=Snipped - Snippet Sharing Server
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/snipped
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/snipped
WorkingDirectory=/var/lib/snipped

# Environment
Environment="RUST_LOG=info"
Environment="DATABASE_URL=sqlite:/var/lib/snipped/snipped.db"

[Install]
WantedBy=multi-user.target
